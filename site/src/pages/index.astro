  <script>
    function initRidgeTimeline() {
      const viewport = document.querySelector<HTMLElement>("[data-ridge-viewport]");
      const cards = document.querySelector<HTMLElement>("[data-ridge-cards]");
      const stems = Array.from(document.querySelectorAll<HTMLElement>("[data-ridge-stem]"));
      const cardEls = Array.from(document.querySelectorAll<HTMLElement>("[data-ridge-card]"));
      const labels = Array.from(document.querySelectorAll<HTMLElement>("[data-ridge-label-post]"));
      if (!viewport || !cards || stems.length === 0) return;

      // On first load, the placeholder sits left of the newest post.
      // Snap the viewport so the FIRST real card (the newest) is centred,
      // leaving the placeholder hidden just off-screen to the left.
      requestAnimationFrame(() => {
        const firstReal = cardEls[0];
        if (!firstReal) return;
        const cardRect = firstReal.getBoundingClientRect();
        const viewRect = viewport!.getBoundingClientRect();
        viewport!.scrollLeft +=
          (cardRect.left - viewRect.left) - (viewRect.width - cardRect.width) / 2;
      });

      const STRIDE = 10;
      const anchorOffset = Math.floor(STRIDE / 2);

      // Returns { closestIndex, peakStemIndex } from current viewport scroll position
      function computeFocus() {
        const viewportRect = viewport!.getBoundingClientRect();
        const focusX = viewportRect.left + viewportRect.width / 2;

        let closestIndex = 0;
        let closestDist = Infinity;
        cardEls.forEach((card, i) => {
          const r = card.getBoundingClientRect();
          const cx = r.left + r.width / 2;
          const d = Math.abs(cx - focusX);
          if (d < closestDist) {
            closestDist = d;
            closestIndex = i;
          }
        });

        const closestRect = cardEls[closestIndex].getBoundingClientRect();
        const closestCx = closestRect.left + closestRect.width / 2;
        const sign = focusX > closestCx ? 1 : -1;
        const neighbour = sign > 0 ? cardEls[closestIndex + 1] : cardEls[closestIndex - 1];
        let frac = 0;
        if (neighbour) {
          const nRect = neighbour.getBoundingClientRect();
          const nCx = nRect.left + nRect.width / 2;
          const span = Math.abs(nCx - closestCx);
          if (span > 0) frac = sign * (Math.abs(focusX - closestCx) / span);
        }
        const continuousCardIndex = closestIndex + frac;
        return {
          closestIndex,
          peak: continuousCardIndex * STRIDE + anchorOffset,
        };
      }

      function update() {
        const { closestIndex, peak } = computeFocus();

        // Mountain tiers (named by mountaineering metaphor):
        //   peak     — 1 tallest bar at the centre
        //   shoulder — 2 bars flanking the peak (NEW, slightly below peak)
        //   ridge    — 2 medium bars
        //   outer    — 2 lower elevation bars
        //   fade     — the long baseline
        // 1 + 2 + 2 + 2 = 7 visible elevated bars in total.
        stems.forEach((stem, i) => {
          const dist = Math.abs(i - peak);
          let h: number;
          let o: number;
          if (dist < 0.5)      { h = 1.0;  o = 0.95; } // peak
          else if (dist < 1.5) { h = 0.78; o = 0.82; } // shoulder
          else if (dist < 2.5) { h = 0.55; o = 0.65; } // ridge
          else if (dist < 3.5) { h = 0.28; o = 0.42; } // outer
          else                 { h = 0.1;  o = 0.18; } // fade
          stem.style.setProperty("--ridge-h", `${h * 100}%`);
          stem.style.setProperty("--ridge-o", `${o}`);
        });

        // Highlight the date label of the active card; dim the rest
        labels.forEach((label) => {
          const idx = parseInt(label.dataset.ridgeLabelPost || "-1", 10);
          label.classList.toggle("is-active", idx === closestIndex);
        });

        // Active card itself gets a subtle highlight
        cardEls.forEach((card, i) => {
          card.classList.toggle("is-active", i === closestIndex);
        });
      }

      viewport.addEventListener("scroll", () => requestAnimationFrame(update), { passive: true });
      window.addEventListener("resize", update);
      requestAnimationFrame(update);

      // Click a labelled anchor → scroll its card into focus
      stems.forEach((stem) => {
        const postAttr = stem.getAttribute("data-ridge-post");
        if (postAttr === null) return;
        stem.style.cursor = "pointer";
        stem.addEventListener("click", () => {
          const cardIdx = parseInt(postAttr, 10);
          scrollCardIntoFocus(cardIdx);
        });
      });

      // Click a date label → scroll its card into focus
      labels.forEach((label) => {
        label.style.cursor = "pointer";
        label.style.pointerEvents = "auto";
        label.addEventListener("click", () => {
          const cardIdx = parseInt(label.dataset.ridgeLabelPost || "0", 10);
          scrollCardIntoFocus(cardIdx);
        });
      });

      function scrollCardIntoFocus(cardIdx: number) {
        const card = cardEls[cardIdx];
        if (!card) return;
        const cardRect = card.getBoundingClientRect();
        const viewRect = viewport!.getBoundingClientRect();
        const targetScroll =
          viewport!.scrollLeft + (cardRect.left - viewRect.left) - (viewRect.width - cardRect.width) / 2;
        viewport!.scrollTo({ left: targetScroll, behavior: "smooth" });
      }

      // ===== Click-and-drag scrolling on the cards row =====
      let isDown = false;
      let startX = 0;
      let startScroll = 0;
      let dragMoved = false;

      viewport.addEventListener("pointerdown", (e: PointerEvent) => {
        if (e.button !== 0) return;
        isDown = true;
        dragMoved = false;
        startX = e.clientX;
        startScroll = viewport!.scrollLeft;
        viewport!.classList.add("is-grabbing");
        viewport!.setPointerCapture(e.pointerId);
      });

      viewport.addEventListener("pointermove", (e: PointerEvent) => {
        if (!isDown) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) dragMoved = true;
        viewport!.scrollLeft = startScroll - dx;
      });

      function endDrag(e: PointerEvent) {
        if (!isDown) return;
        isDown = false;
        viewport!.classList.remove("is-grabbing");
        try { viewport!.releasePointerCapture(e.pointerId); } catch {}
      }
      viewport.addEventListener("pointerup", endDrag);
      viewport.addEventListener("pointercancel", endDrag);

      cardEls.forEach((card) => {
        card.addEventListener("click", (e) => {
          if (dragMoved) e.preventDefault();
        });
      });

      // ===== Click-and-drag scrubbing on the ridge rail =====
      // Dragging the rail moves the cards viewport proportionally — like a
      // video scrubber: full rail width = full card scroll range.
      const rail = document.querySelector<HTMLElement>("[data-ridge-rail]");
      if (rail) {
        let railDown = false;
        let railStartX = 0;
        let railStartScroll = 0;
        let railRatio = 1;

        function maxViewportScroll() {
          return viewport!.scrollWidth - viewport!.clientWidth;
        }

        rail.addEventListener("pointerdown", (e: PointerEvent) => {
          if (e.button !== 0) return;
          railDown = true;
          railStartX = e.clientX;
          railStartScroll = viewport!.scrollLeft;
          // Map: dragging the full rail width should cover the full scroll range
          const railWidth = rail.clientWidth;
          railRatio = railWidth > 0 ? maxViewportScroll() / railWidth : 1;
          rail.classList.add("is-scrubbing");
          rail.setPointerCapture(e.pointerId);
          // Prevent native drag (text selection etc.)
          e.preventDefault();
        });

        rail.addEventListener("pointermove", (e: PointerEvent) => {
          if (!railDown) return;
          const dx = e.clientX - railStartX;
          viewport!.scrollLeft = railStartScroll + dx * railRatio;
        });

        function endRailDrag(e: PointerEvent) {
          if (!railDown) return;
          railDown = false;
          rail!.classList.remove("is-scrubbing");
          try { rail!.releasePointerCapture(e.pointerId); } catch {}
        }
        rail.addEventListener("pointerup", endRailDrag);
        rail.addEventListener("pointercancel", endRailDrag);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initRidgeTimeline);
    } else {
      initRidgeTimeline();
    }
    document.addEventListener("astro:page-load", initRidgeTimeline);
  </script>

