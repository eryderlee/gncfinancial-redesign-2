<!-- Hero background switcher logic: cycles through all options on button
     click and via the ?hero= URL param. Curtain restores the video; the
     other options swap to the static poster of the selected image. -->
<script is:inline>
  (function() {
    const OPTIONS = [
      'curtain',
      'listening',
      'adviser-meeting',
      'eucalypt',
      'hills',
      'valley',
      'boardroom',
      'reception',
      'building',
      'dusk-office',
      'brass',
      'corridor',
      'quiet-office',
      'ledger',
      'coffee',
      'meeting',
      'laughing',
      'review',
      'welcome',
      'report',
      'unsplash',
      'recolor-1',
      'recolor-2',
      'recolor-3',
      'recolor-4',
    ];
    const POSTER_MAP = {
      curtain: '/hero/poster.jpg',
      eucalypt: '/hero/poster-eucalypt.jpg',
      hills: '/hero/poster-hills.jpg',
      valley: '/hero/poster-valley.jpg',
      boardroom: '/hero/poster-boardroom.jpg',
      reception: '/hero/poster-reception.jpg',
      building: '/hero/poster-building.jpg',
      'dusk-office': '/hero/poster-dusk-office.jpg',
      brass: '/hero/poster-brass.jpg',
      corridor: '/hero/poster-corridor.jpg',
      'quiet-office': '/hero/poster-quiet-office.jpg',
      ledger: '/hero/poster-ledger.jpg',
      coffee: '/hero/poster-coffee.jpg',
      meeting: '/hero/poster-meeting.jpg',
      'adviser-meeting': '/hero/poster-adviser-meeting.jpg',
      laughing: '/hero/poster-laughing.jpg',
      review: '/hero/poster-review.jpg',
      listening: '/hero/poster-listening.jpg',
      welcome: '/hero/poster-welcome.jpg',
      report: '/hero/poster-report.jpg',
      unsplash: '/hero/poster-unsplash.jpg',
      'recolor-1': '/hero/poster-recolor-1.jpg',
      'recolor-2': '/hero/poster-recolor-2.jpg',
      'recolor-3': '/hero/poster-recolor-3.jpg',
      'recolor-4': '/hero/poster-recolor-4.jpg',
    };
    const LABELS = {
      curtain: 'Curtain',
      eucalypt: 'Eucalypt',
      hills: 'Hills',
      valley: 'Valley',
      boardroom: 'Boardroom',
      reception: 'Reception',
      building: 'Building',
      'dusk-office': 'Dusk office',
      brass: 'Brass detail',
      corridor: 'Corridor',
      'quiet-office': 'Quiet office',
      ledger: 'Ledger',
      coffee: 'Coffee',
      meeting: 'Meeting',
      'adviser-meeting': 'Adviser meeting',
      laughing: 'Laughing',
      review: 'Reviewing',
      listening: 'Listening (video)',
      welcome: 'Welcome',
      report: 'Reading report',
      unsplash: 'Unsplash ref',
      'recolor-1': 'Recolour 1',
      'recolor-2': 'Recolour 2',
      'recolor-3': 'Recolour 3',
      'recolor-4': 'Recolour 4',
    };
    // Options that have a full video (not just a still poster). When the
    // user selects these, the script swaps the video sources AND shows the
    // video element. Other options just show the static poster img.
    const VIDEO_MAP = {
      curtain: { webm: '/hero/hero.webm', mp4: '/hero/hero.mp4' },
      listening: { webm: '/hero/hero-listening.webm', mp4: '/hero/hero-listening.mp4' },
    };

    const params = new URLSearchParams(window.location.search);
    let current = params.get('hero') || 'curtain';
    if (OPTIONS.indexOf(current) === -1) current = 'curtain';

    function setVideoSources(videoEl, urls, posterUrl) {
      if (!videoEl) return;
      const sources = videoEl.querySelectorAll('source');
      if (sources[0]) sources[0].src = urls.webm;
      if (sources[1]) sources[1].src = urls.mp4;
      if (posterUrl) videoEl.setAttribute('poster', posterUrl);
      videoEl.load();
    }

    function apply(option) {
      const videoUrls = VIDEO_MAP[option];
      const posterSrc = POSTER_MAP[option];
      const hasVideo = !!videoUrls;

      const heroBg = document.querySelector('.hero-video-bg');
      const heroPoster = document.querySelector('.hero-video-poster');
      const bleedBg = document.querySelector('.hero-bleed-video');
      const bleedPoster = document.querySelector('.hero-bleed-poster');

      if (hasVideo) {
        // Swap video sources for both hero bg and bleed; show the video
        setVideoSources(heroBg, videoUrls, posterSrc);
        setVideoSources(bleedBg, videoUrls, posterSrc);
        if (heroBg) heroBg.style.display = '';
        if (bleedBg) bleedBg.style.display = '';
        // Reset poster img to CSS default (hidden on desktop, visible on mobile)
        if (heroPoster) heroPoster.style.display = '';
        if (bleedPoster) bleedPoster.style.display = '';
      } else {
        // Still-only: hide videos, force poster img on
        if (heroBg) heroBg.style.display = 'none';
        if (bleedBg) bleedBg.style.display = 'none';
        if (heroPoster) heroPoster.style.display = 'block';
        if (bleedPoster) bleedPoster.style.display = 'block';
      }

      // Update poster src on every change (used as bg fallback when video
      // hasn't loaded yet, and as the actual visible image for still-only).
      if (heroPoster) heroPoster.src = posterSrc;
      if (bleedPoster) bleedPoster.src = posterSrc;

      const label = document.querySelector('.hero-bg-switcher-label');
      if (label) label.textContent = LABELS[option];

      const url = new URL(window.location.href);
      if (option === 'curtain') url.searchParams.delete('hero');
      else url.searchParams.set('hero', option);
      history.replaceState({}, '', url);
    }

    function next() {
      const idx = OPTIONS.indexOf(current);
      current = OPTIONS[(idx + 1) % OPTIONS.length];
      const btn = document.getElementById('hero-bg-switcher');
      if (btn) {
        btn.classList.add('is-cycling');
        setTimeout(function() { btn.classList.remove('is-cycling'); }, 500);
      }
      apply(current);
    }

    function init() {
      apply(current);
      const btn = document.getElementById('hero-bg-switcher');
      if (btn) btn.addEventListener('click', next);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
