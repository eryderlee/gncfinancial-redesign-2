---
import Page from '../../layouts/Page.astro';

export function getStaticPaths() {
  const posts = [
    {
      slug: 'tax-time-2025-small-business',
      title: 'Tax Time 2025: What Every Small Business Owner Needs to Know',
      category: 'Tax',
      date: '2025-06-01',
      excerpt: 'Key deadlines, new deductions, and common mistakes to avoid this financial year. A practical checklist for Hills District business owners.',
      body: 'This is a placeholder post. The full content will be migrated from the existing GNC Financial website.',
    },
    {
      slug: 'xero-vs-myob-vs-quickbooks',
      title: 'Xero vs MYOB vs QuickBooks: Which Is Right for Your Business?',
      category: 'Bookkeeping',
      date: '2025-04-15',
      excerpt: 'We break down the three biggest cloud accounting platforms to help you pick the one that fits your workflow and budget.',
      body: 'This is a placeholder post. The full content will be migrated from the existing GNC Financial website.',
    },
    {
      slug: 'accountant-for-investment-property',
      title: 'Do You Actually Need an Accountant for Your Investment Property?',
      category: 'Property',
      date: '2025-03-10',
      excerpt: "Negative gearing, depreciation schedules, CGT — here's when DIY stops making sense and professional help pays for itself.",
      body: 'This is a placeholder post. The full content will be migrated from the existing GNC Financial website.',
    },
    {
      slug: 'crypto-tax-australia-2025',
      title: 'Crypto Tax in Australia: What the ATO Expects in 2025',
      category: 'Tax',
      date: '2025-02-20',
      excerpt: "The ATO is watching crypto closely. Here's what you need to report, how CGT applies, and the records you should be keeping.",
      body: 'This is a placeholder post. The full content will be migrated from the existing GNC Financial website.',
    },
    {
      slug: 'setting-up-first-smsf',
      title: 'Setting Up Your First SMSF: Is It Worth It?',
      category: 'SMSF',
      date: '2025-01-15',
      excerpt: "Self-managed super funds offer control and flexibility — but they're not for everyone. We outline the costs, compliance, and who benefits most.",
      body: 'This is a placeholder post. The full content will be migrated from the existing GNC Financial website.',
    },
    {
      slug: 'abn-acn-tfn-explained',
      title: 'ABN, ACN, TFN — What Do You Actually Need?',
      category: 'Business',
      date: '2024-11-08',
      excerpt: "Starting a business? Here's a plain-English guide to the registrations you need (and the ones you probably don't).",
      body: 'This is a placeholder post. The full content will be migrated from the existing GNC Financial website.',
    },
    {
      slug: 'bas-quarterly-vs-monthly',
      title: 'BAS Lodgment: Quarterly vs Monthly — Which Is Better?',
      category: 'BAS',
      date: '2024-09-22',
      excerpt: 'The answer depends on your turnover and cash flow. We break down the pros and cons so you can choose with confidence.',
      body: 'This is a placeholder post. The full content will be migrated from the existing GNC Financial website.',
    },
    {
      slug: 'tax-deductions-tradies',
      title: 'Five Tax Deductions Hills District Tradies Often Miss',
      category: 'Tax',
      date: '2024-08-05',
      excerpt: "Tools, travel, training, and more — if you're a tradie, make sure you're not leaving money on the table at tax time.",
      body: 'This is a placeholder post. The full content will be migrated from the existing GNC Financial website.',
    },
  ];

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<Page
  title={post.title}
  description={post.excerpt}
>
  <article class="py-20 md:py-24">
    <div class="max-w-[65ch] mx-auto px-5 md:px-10">
      <!-- Meta -->
      <div class="mb-8">
        <a href="/insights/" class="text-sm text-muted-500 hover:text-accent-600 transition-colors duration-150 mb-4 inline-block">
          &larr; Back to Insights
        </a>
        <span class="inline-block text-xs font-medium bg-accent-50 text-accent-950 rounded-full px-3 py-1 mb-3 ml-3">
          {post.category}
        </span>
        <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 leading-tight mb-3">
          {post.title}
        </h1>
        <time class="text-sm text-muted-500" datetime={post.date}>
          {new Date(post.date).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
      </div>

      <!-- Body -->
      <div class="prose text-ink-700 leading-relaxed space-y-4">
        <p class="text-lg text-ink-500 italic">{post.excerpt}</p>
        <p data-placeholder="true">{post.body}</p>
      </div>

      <!-- CTA -->
      <div class="mt-16 pt-8 border-t border-surface-300">
        <p class="text-ink-600 mb-4">Have questions about this topic?</p>
        <a
          href="/contact/"
          class="inline-flex items-center text-sm font-medium text-ink-800 hover:text-accent-700 underline underline-offset-4 decoration-ink-300 hover:decoration-accent-600 transition-colors duration-150"
        >
          Get in touch with our team &rarr;
        </a>
      </div>
    </div>
  </article>
</Page>
