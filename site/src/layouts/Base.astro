---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;
const canonical = `https://gncfinancial.com.au${canonicalPath || Astro.url.pathname}`;
const fullTitle = `${title} — GNC Financial · Hills District Accountants`;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_AU" />
    <ClientRouter />
    <!-- Google Fonts: Inter, Fraunces, Lora, Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400..700&family=Fraunces:opsz,wght@9..144,400..700&family=Lora:wght@400..700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
    <slot name="head" />
    <!-- Apply persisted theme before paint. Default = navy (ported);
         user must explicitly toggle to 'warm' to see the original orange.
         Also applies on Astro view-transition swaps so the theme persists
         when navigating between pages (otherwise inner pages flash to the
         original theme during the swap). -->
    <script is:inline>
      (function() {
        function applyTheme(doc) {
          try {
            var t = localStorage.getItem('gnc-theme');
            if (t !== 'warm') doc.documentElement.setAttribute('data-theme', 'ported');
            else doc.documentElement.removeAttribute('data-theme');
          } catch (e) {
            doc.documentElement.setAttribute('data-theme', 'ported');
          }
        }
        applyTheme(document);
        document.addEventListener('astro:before-swap', function(event) {
          applyTheme(event.newDocument);
        });
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Reading progress bar -->
    <div class="reading-progress" aria-hidden="true"></div>
    <slot name="header" />
    <main class="flex-1" transition:animate="fade">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
