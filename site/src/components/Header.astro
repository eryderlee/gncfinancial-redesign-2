---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Services', href: '/services/' },
  { label: 'Insights', href: '/insights/' },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header
  class="sticky top-0 z-50 transition-all duration-300 bg-surface-50/95 backdrop-blur-sm border-b border-surface-300"
  id="site-header"
>
  <div class="max-w-[1200px] mx-auto px-5 md:px-10 flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex-shrink-0" aria-label="GNC Financial home" transition:name="logo">
      <img
        src="/logo-transparent.png"
        alt="GNC Financial"
        width="180"
        height="40"
        class="site-logo-default h-11 md:h-14 w-auto transition-all duration-300"
      />
      <img
        src="/logo-ported.png"
        alt="GNC Financial"
        width="180"
        height="40"
        class="site-logo-ported h-11 md:h-14 w-auto transition-all duration-300"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'site-nav-link text-sm font-medium transition-colors duration-150',
            currentPath === href ? 'site-nav-active' : '',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Right cluster: phone + CTA -->
    <div class="hidden md:flex items-center gap-5 lg:gap-6">
      <!-- Phone (lg+) -->
      <a
        href="tel:0284032770"
        class="site-nav-phone hidden lg:flex items-center gap-2 text-sm font-medium transition-colors duration-150"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        02 8403 2770
      </a>

      <!-- Book a call CTA (desktop) -->
      <a
        href="/contact/"
        class="site-nav-cta inline-flex items-center gap-2 text-sm font-medium rounded-full border px-4 py-2 transition-all duration-200"
        aria-label="Book a call"
      >
        <span>Book a call</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="site-nav-cta-arrow shrink-0" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>

      <!-- Theme toggle (compare current vs ported palette) -->
      <button
        type="button"
        id="theme-toggle"
        class="theme-toggle"
        aria-label="Toggle theme"
        title="Toggle colour theme"
      >
        <span class="theme-toggle-swatch theme-toggle-swatch-1" aria-hidden="true"></span>
        <span class="theme-toggle-swatch theme-toggle-swatch-2" aria-hidden="true"></span>
      </button>
    </div>

    <!-- Mobile menu button -->
    <button
      class="site-nav-menu-btn md:hidden p-2 transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
      id="mobile-menu-btn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </button>
  </div>
</header>

<!-- Backdrop scrim behind the drawer — tappable to dismiss. Kept OUTSIDE
     <header> for the same reason as the drawer below. -->
<div
  id="mobile-menu-backdrop"
  class="mobile-menu-backdrop md:hidden"
  aria-hidden="true"
></div>

<!-- Mobile menu drawer — kept OUTSIDE <header> because the header uses
     backdrop-filter, which creates a containing block for fixed-position
     descendants and would shrink this drawer to the header's bounds. -->
<div
  id="mobile-menu"
  class="mobile-menu-overlay md:hidden"
  aria-hidden="true"
>
  <!-- Top bar: logo + close -->
  <div class="mobile-menu-header">
    <img src="/logo-transparent.png" alt="GNC Financial" width="140" height="32" />
    <button class="mobile-menu-close" aria-label="Close menu" id="mobile-menu-close">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>

  <!-- Section label -->
  <span class="mobile-menu-label">Navigate</span>

  <!-- Nav links -->
  <nav class="mobile-menu-nav" aria-label="Mobile navigation">
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class:list={['mobile-menu-link', currentPath === href ? 'is-active' : '']}
      >
        <span>{label}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    ))}
  </nav>

  <!-- Footer: phone + CTA -->
  <div class="mobile-menu-footer">
    <a href="tel:0284032770" class="mobile-menu-phone">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span>02 8403 2770</span>
    </a>
    <a href="/contact/" class="mobile-menu-cta">Book a free consult</a>
  </div>
</div>

<script>
  function initHeader() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mobile-menu-close');
    const backdrop = document.getElementById('mobile-menu-backdrop');

    function openMenu() {
      menu?.classList.add('mobile-menu-open');
      backdrop?.classList.add('mobile-menu-open');
      menu?.setAttribute('aria-hidden', 'false');
      btn?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu?.classList.remove('mobile-menu-open');
      backdrop?.classList.remove('mobile-menu-open');
      menu?.setAttribute('aria-hidden', 'true');
      btn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    btn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);
    menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));

    // Theme toggle: cycles between 'ported' (navy — default) and 'warm'
    // (original orange/cream). State stored in localStorage so it persists.
    const themeBtn = document.getElementById('theme-toggle');
    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme === 'ported' ? 'ported' : 'warm';
        const next = current === 'ported' ? 'warm' : 'ported';
        if (next === 'warm') {
          document.documentElement.removeAttribute('data-theme');
        } else {
          document.documentElement.setAttribute('data-theme', 'ported');
        }
        try { localStorage.setItem('gnc-theme', next); } catch (e) {}
      });
    }
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
