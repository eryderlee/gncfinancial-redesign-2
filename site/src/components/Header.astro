---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Services', href: '/services/' },
  { label: 'Insights', href: '/insights/' },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header
  class:list={[
    "sticky top-0 z-50 transition-all duration-300",
    isHome ? "site-header-home" : "bg-surface-50/95 backdrop-blur-sm border-b border-surface-300",
  ]}
  id="site-header"
  data-home={isHome ? 'true' : 'false'}
>
  <div class="max-w-[1200px] mx-auto px-5 md:px-10 flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex-shrink-0" aria-label="GNC Financial home" transition:name="logo">
      <img
        src="/logo-transparent.png"
        alt="GNC Financial"
        width="180"
        height="40"
        class:list={[
          "h-9 md:h-10 w-auto transition-all duration-300",
          isHome && "site-header-logo",
        ]}
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'site-nav-link text-sm font-medium transition-colors duration-150',
            currentPath === href ? 'site-nav-active' : '',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Phone (desktop) -->
    <a
      href="tel:0284032770"
      class="site-nav-phone hidden lg:flex items-center gap-2 text-sm font-medium transition-colors duration-150"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      02 8403 2770
    </a>

    <!-- Mobile menu button -->
    <button
      class="site-nav-menu-btn md:hidden p-2 transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
      id="mobile-menu-btn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Mobile menu overlay (forced solid background) -->
  <div
    id="mobile-menu"
    class="mobile-menu-overlay md:hidden"
    aria-hidden="true"
  >
    <div class="flex items-center justify-between px-5 h-16">
      <img src="/logo-transparent.png" alt="GNC Financial" width="160" height="36" class="h-9 w-auto invert" />
      <button class="p-2 text-white hover:text-accent-400 transition-colors" aria-label="Close menu" id="mobile-menu-close">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <nav class="flex flex-col items-center gap-7 pt-16" aria-label="Mobile navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'text-2xl font-display font-medium transition-colors duration-150',
            currentPath === href ? 'text-accent-500' : 'text-white hover:text-accent-400',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="tel:0284032770"
        class="mt-8 inline-flex items-center gap-2 text-base text-surface-300 hover:text-accent-400 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        02 8403 2770
      </a>
      <a
        href="/contact/"
        class="mt-6 inline-flex items-center bg-accent-600 hover:bg-accent-500 text-white font-medium py-3 px-7 rounded-lg transition-colors text-sm"
      >
        Book a free consult
      </a>
    </nav>
  </div>
</header>

<script>
  function initHeader() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mobile-menu-close');
    const header = document.getElementById('site-header');

    function openMenu() {
      menu?.classList.add('mobile-menu-open');
      menu?.setAttribute('aria-hidden', 'false');
      btn?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu?.classList.remove('mobile-menu-open');
      menu?.setAttribute('aria-hidden', 'true');
      btn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    btn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));

    // Transparent → solid header on scroll (home page only)
    if (header?.dataset.home === 'true') {
      const onScroll = () => {
        if (window.scrollY > 60) {
          header.classList.add('site-header-scrolled');
        } else {
          header.classList.remove('site-header-scrolled');
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
