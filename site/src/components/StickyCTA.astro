---
// Mobile-only sticky CTA bar — hides when footer is visible
---

<div
  id="sticky-cta"
  class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-accent-600 p-3 transform transition-transform duration-300 translate-y-full"
>
  <a
    href="/contact/"
    class="block w-full text-center text-white font-medium text-sm py-2.5 rounded-lg bg-accent-700 hover:bg-accent-800 transition-colors duration-150"
  >
    Book a free consult
  </a>
</div>

<script>
  function initStickyCta() {
    const stickyCta = document.getElementById('sticky-cta');
    if (!stickyCta) return;

    const hero = document.querySelector<HTMLElement>('.hero-anchor');
    const footer = document.querySelector<HTMLElement>('footer');

    let footerVisible = false;

    // Hero visibility is measured from scroll position rather than via
    // IntersectionObserver. Safari (especially iOS) sometimes mis-reports
    // the initial intersection state when the script runs before layout
    // settles, leaving the bar visible over the hero.
    const sync = () => {
      let heroVisible = false;
      if (hero) {
        const rect = hero.getBoundingClientRect();
        heroVisible = rect.bottom > 0;
      }
      const shouldShow = !heroVisible && !footerVisible;
      stickyCta.classList.toggle('translate-y-full', !shouldShow);
    };

    if (footer) {
      const footerObserver = new IntersectionObserver(
        ([entry]) => {
          footerVisible = entry.isIntersecting;
          sync();
        },
        { threshold: 0 }
      );
      footerObserver.observe(footer);
    }

    let rafId = 0;
    const onScroll = () => {
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = 0;
        sync();
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', sync);
    sync();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStickyCta);
  } else {
    initStickyCta();
  }
  document.addEventListener('astro:page-load', initStickyCta);
</script>
