---
// Mobile-only sticky CTA bar — hides when footer is visible
---

<div
  id="sticky-cta"
  class="sticky-cta fixed bottom-0 left-0 right-0 z-40 md:hidden bg-accent-600 p-3 sticky-cta-hidden"
>
  <a
    href="/contact/"
    class="block w-full text-center text-white font-medium text-sm py-2.5 rounded-lg bg-accent-700 hover:bg-accent-800 transition-colors duration-150"
  >
    Book a free consult
  </a>
</div>

<style is:global>
  /* Custom hide rule that handles Safari's dynamic viewport: translate
     past the layout viewport edge AND flip visibility once the slide-down
     transition completes, so it can't peek out from under the URL bar
     when the bar shrinks/grows. */
  .sticky-cta {
    transform: translateY(0);
    visibility: visible;
    transition:
      transform 300ms cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0s 0s;
  }
  .sticky-cta.sticky-cta-hidden {
    /* 100% own-height + a chunky safety margin so Safari's URL bar / safe
       area can't leave a sliver visible. */
    transform: translateY(calc(100% + 2.5rem));
    visibility: hidden;
    /* Delay the visibility flip until AFTER the slide-down transition
       finishes, so the slide animation is preserved. */
    transition:
      transform 300ms cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0s 300ms;
  }
</style>

<script>
  // Module-level cleanup so re-inits on astro:page-load don't stack listeners.
  let __stickyCleanup: (() => void) | null = null;

  function initStickyCta() {
    __stickyCleanup?.();

    const stickyCta = document.getElementById('sticky-cta');
    if (!stickyCta) return;
    // Don't show the sticky "Book a free consult" CTA on the contact
    // page itself — they're already there.
    if (window.location.pathname.startsWith('/contact')) {
      stickyCta.style.display = 'none';
      return;
    }

    // Scroll-position check (works reliably on Safari, where IntersectionObserver
    // can mis-fire on full-viewport-height targets / after view transitions).
    const hero = document.querySelector<HTMLElement>('.hero-anchor');
    const footer = document.querySelector<HTMLElement>('footer');

    const sync = () => {
      const vh = window.innerHeight;

      // Hero: hide CTA while ANY part of hero is still on screen
      // (i.e. its bottom hasn't passed the top of the viewport).
      // No hero on this page → treat as "past hero".
      const heroBottom = hero ? hero.getBoundingClientRect().bottom : -1;
      const pastHero = heroBottom <= 0;

      // Footer: hide CTA when footer's top has entered the viewport.
      const footerTop = footer ? footer.getBoundingClientRect().top : Number.POSITIVE_INFINITY;
      const footerVisible = footerTop < vh;

      const shouldShow = pastHero && !footerVisible;
      stickyCta.classList.toggle('sticky-cta-hidden', !shouldShow);
    };

    let rafScheduled = false;
    const onScroll = () => {
      if (rafScheduled) return;
      rafScheduled = true;
      requestAnimationFrame(() => {
        rafScheduled = false;
        sync();
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', sync);

    __stickyCleanup = () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', sync);
    };

    sync();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStickyCta);
  } else {
    initStickyCta();
  }
  document.addEventListener('astro:page-load', initStickyCta);
</script>
