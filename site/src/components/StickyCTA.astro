---
// Mobile-only sticky CTA bar — hides when footer is visible
---

<div
  id="sticky-cta"
  class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-accent-600 p-3 transform transition-transform duration-300"
>
  <a
    href="/contact/"
    class="block w-full text-center text-white font-medium text-sm py-2.5 rounded-lg bg-accent-700 hover:bg-accent-800 transition-colors duration-150"
  >
    Book a free consult
  </a>
</div>

<script>
  const stickyCta = document.getElementById('sticky-cta');
  const footer = document.querySelector('footer');

  if (stickyCta && footer) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          stickyCta.classList.add('translate-y-full');
        } else {
          stickyCta.classList.remove('translate-y-full');
        }
      },
      { threshold: 0 }
    );
    observer.observe(footer);
  }
</script>
