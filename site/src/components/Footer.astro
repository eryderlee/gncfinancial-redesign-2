---
const currentYear = new Date().getFullYear();
---

<footer class="bg-ink-900 text-surface-300">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <!-- Col 1: Logo & tagline -->
      <div>
        <img
          src="/logo-transparent.png"
          alt="GNC Financial"
          width="160"
          height="36"
          class="h-8 w-auto brightness-0 invert mb-4"
        />
        <p class="text-surface-500 text-sm leading-relaxed max-w-xs">
          Local accountants in the Hills District. Straightforward advice for individuals, families, and small businesses.
        </p>
        <!-- Social icons -->
        <div class="flex gap-4 mt-6">
          <a href="https://www.instagram.com/gncfinancial/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-surface-500 hover:text-accent-400 transition-colors duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="https://www.facebook.com/profile.php?id=61568291158118" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-surface-500 hover:text-accent-400 transition-colors duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/www.gncfinancial.com.au/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-surface-500 hover:text-accent-400 transition-colors duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Navigation -->
      <div>
        <h3 class="text-surface-100 font-medium text-sm uppercase tracking-wider mb-4">Navigate</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="hover:text-surface-100 transition-colors duration-150">Home</a></li>
          <li><a href="/about/" class="hover:text-surface-100 transition-colors duration-150">About</a></li>
          <li><a href="/services/" class="hover:text-surface-100 transition-colors duration-150">Services</a></li>
          <li><a href="/insights/" class="hover:text-surface-100 transition-colors duration-150">Insights</a></li>
          <li><a href="/contact/" class="hover:text-surface-100 transition-colors duration-150">Contact</a></li>
        </ul>
        <h3 class="text-surface-100 font-medium text-sm uppercase tracking-wider mb-4 mt-8">Legal</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/privacy/" class="hover:text-surface-100 transition-colors duration-150">Privacy Policy</a></li>
          <li><a href="/disclaimer/" class="hover:text-surface-100 transition-colors duration-150">Disclaimer</a></li>
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div>
        <h3 class="text-surface-100 font-medium text-sm uppercase tracking-wider mb-4">Contact</h3>
        <address class="not-italic text-sm space-y-3">
          <p>
            Suite 111, 33 Lexington Drive<br />
            East Block, Level 1<br />
            Bella Vista NSW 2153
          </p>
          <p>
            <a href="tel:0284032770" class="hover:text-surface-100 transition-colors duration-150">02 8403 2770</a><br />
            <a href="tel:0288606520" class="hover:text-surface-100 transition-colors duration-150">02 8860 6520</a>
          </p>
          <p>
            <a href="mailto:admin@gncfinancial.com.au" class="hover:text-surface-100 transition-colors duration-150">admin@gncfinancial.com.au</a>
          </p>
        </address>
        <!-- IPA badge placeholder -->
        <div class="mt-6 inline-block bg-surface-900 rounded px-3 py-2 text-xs text-surface-400" data-placeholder="true">
          IPA Member · Registered BAS Agent
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-surface-800 mt-12 pt-8 text-center text-xs text-surface-600">
      &copy; {currentYear} GNC Financial. All rights reserved.
    </div>
  </div>
</footer>
