---
// Scroll-drawn orange line.
// Sits absolutely inside a `position: relative` parent, builds a curved SVG path
// from the top of the parent down to the element with id="line-target", then
// animates stroke-dashoffset on scroll so the line "draws itself" from the
// credo dot down to the booking CTA.
//
// Vanilla JS — no GSAP — uses requestAnimationFrame + scroll listener.
---

<div class="scroll-line" data-scroll-line aria-hidden="true">
  <!-- Two stacked SVGs sharing the same path geometry. The "dark" layer uses
       multiply blending so it darkens light backgrounds; the "light" layer
       uses plus-lighter so it glows on dark backgrounds. Each layer is only
       visible on the bg type it's tuned for. -->
  <svg class="scroll-line-svg scroll-line-dark" data-scroll-line-svg fill="none" overflow="visible">
    <path
      data-scroll-line-path
      fill="none"
      stroke="var(--color-accent-600)"
      stroke-width="1.5"
      stroke-linecap="round"
    />
  </svg>
  <svg class="scroll-line-svg scroll-line-light" data-scroll-line-svg-light fill="none" overflow="visible">
    <path
      data-scroll-line-path-light
      fill="none"
      stroke="var(--color-accent-600)"
      stroke-width="1.6"
      stroke-linecap="round"
    />
  </svg>
</div>

<style is:global>
  .scroll-line-parent { position: relative; }

  /* Line sits BEHIND any boxed content (cards, iframes, callouts) but on
     top of the page background. Boxes get z-index: 2 below. */
  .scroll-line {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.6s ease-out;

    /* Dim the line where it traverses the credo (Down-to-earth) section,
       then ramp to full alpha at the credo → services boundary. Both
       CSS variables are set per-frame by the scroll-line script:
         --scroll-line-fade-end: percentage of the wrapper height where
                                 the credo section ends (defaults to 0%
                                 + alpha 1 → no visible dimming).
         --scroll-line-fade-alpha: alpha of the dim portion (0–1). */
    --scroll-line-fade-end: 0%;
    --scroll-line-fade-alpha: 1;
    --scroll-line-fade-ramp: 4%;
    -webkit-mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, var(--scroll-line-fade-alpha)) 0%,
      rgba(0, 0, 0, var(--scroll-line-fade-alpha))
        calc(var(--scroll-line-fade-end) - var(--scroll-line-fade-ramp)),
      rgba(0, 0, 0, 1) calc(var(--scroll-line-fade-end) + var(--scroll-line-fade-ramp)),
      rgba(0, 0, 0, 1) 100%
    );
            mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, var(--scroll-line-fade-alpha)) 0%,
      rgba(0, 0, 0, var(--scroll-line-fade-alpha))
        calc(var(--scroll-line-fade-end) - var(--scroll-line-fade-ramp)),
      rgba(0, 0, 0, 1) calc(var(--scroll-line-fade-end) + var(--scroll-line-fade-ramp)),
      rgba(0, 0, 0, 1) 100%
    );
  }
  .scroll-line.is-ready { opacity: 1; }

  .scroll-line-svg {
    position: absolute;
    top: 0;
    left: 0;
    overflow: visible;
  }
  /* Dark layer: same multiply blend + opacity the original line had,
     so on cream/light backgrounds it looks identical to before. */
  .scroll-line-dark {
    mix-blend-mode: multiply;
    opacity: 0.55;
  }
  /* Light layer: `lighten` takes max(src, dest) per channel. The stroke
     colour (#E8801A) sits BELOW cream's R/G/B in every channel, so on
     light backgrounds the layer literally cannot push any pixel — it's
     invisible. On near-black, every channel wins → clean orange line. */
  .scroll-line-light {
    mix-blend-mode: lighten;
    opacity: 0.95;
  }

  /* Every direct content child of a section is lifted ABOVE the line, so the
     line passes BEHIND text, the Google-reviews pill, and any other element
     a section renders. The dot-grid / texture overlays use the .absolute
     utility class — those are excluded so they stay below the line. */
  .scroll-line-parent section > *:not(.absolute) {
    position: relative;
    z-index: 2;
  }

  /* Specific cards, iframes, and rails already get z-index: 2 above; this
     keeps the existing rules working when an overlay sits inside a deeper
     wrapper instead of being a direct child of <section>. */
  .scroll-line-parent .ridge-card,
  .scroll-line-parent .ridge-card-placeholder,
  .scroll-line-parent .ridge-cards-viewport,
  .scroll-line-parent .reviews-marquee,
  .scroll-line-parent .review-card,
  .scroll-line-parent .card-hover,
  .scroll-line-parent .stat-callout,
  .scroll-line-parent .platform-card,
  .scroll-line-parent .specialist-card,
  .scroll-line-parent .advisory-step,
  .scroll-line-parent iframe,
  .scroll-line-parent .ridge-rail,
  .scroll-line-parent .ridge-labels-row {
    position: relative;
    z-index: 2;
  }

  /* CTA arrival glow — fires when the line tip reaches the booking button */
  #line-target {
    position: relative;
    z-index: 2;
    transition: box-shadow 0.5s ease-out, transform 0.4s ease-out;
  }
  #line-target.cta-arrived {
    box-shadow:
      0 0 0 6px rgba(232, 128, 26, 0.18),
      0 0 28px 6px rgba(232, 128, 26, 0.55),
      0 10px 22px -4px rgba(232, 128, 26, 0.45);
    transform: translateY(-2px) scale(1.02);
  }

  /* Any direct wrapper that contains an iframe (e.g. the Google map card)
     gets lifted above the line so the line passes behind it. */
  .scroll-line-parent *:has(> iframe) {
    position: relative;
    z-index: 2;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-line { display: none; }
  }
</style>

<script>
  // Module-level cleanup so each call to initScrollLine() (e.g. on every
  // astro:page-load) tears down the previous instance's listeners before
  // wiring up new ones. Without this, listeners stack and each scroll event
  // fires update() multiple times — the cause of the frame-by-frame jank.
  let __slCleanup: (() => void) | null = null;

  function initScrollLine() {
    __slCleanup?.();

    const wrapper = document.querySelector<HTMLElement>("[data-scroll-line]");
    const svg = document.querySelector<SVGSVGElement>("[data-scroll-line-svg]");
    const path = document.querySelector<SVGPathElement>("[data-scroll-line-path]");
    if (!wrapper || !svg || !path) return;

    let totalLength = 0;
    let parent: HTMLElement | null = null;
    let target: HTMLElement | null = null;
    let source: HTMLElement | null = null;
    let ctaReached = false;

    function buildPath(startX: number, endX: number, h: number, amp: number): string {
      // Two cubic bezier sweeps that snake from (startX, 0) down to (endX, h)
      // within the SVG's local coordinate space.
      const midX = (startX + endX) / 2;
      const cp1x = startX - amp * 0.26;
      const cp2x = startX - amp;
      const mid = h * 0.5;
      const peak2 = h * 0.75;
      const scp1x = midX + amp * 0.5;
      return (
        `M ${startX} 0 ` +
        `C ${cp1x} ${h * 0.13}, ${cp2x} ${h * 0.30}, ${midX} ${mid} ` +
        `S ${scp1x} ${peak2}, ${endX} ${h}`
      );
    }

    function setup() {
      // Just bind references — all geometry is handled by update() so we
      // never write a stale (uncompensated) position to the DOM that would
      // flash on paint before update() runs.
      parent = wrapper!.parentElement;
      target = document.getElementById("line-target");
      source = document.getElementById("line-source");
    }

    let lastH = 0;
    let lastStartX = 0;
    let lastEndX = 0;

    // The credo block has a `.reveal` transition that uses translateY(32 → 0).
    // getBoundingClientRect() includes that transform, so the dot's measured
    // top is wrong while the animation is in progress. Compensate by reading
    // the parent's current transform matrix and subtracting its Y offset —
    // the result is the dot's RESTING position regardless of animation state.
    function getTransformY(el: Element | null): { x: number; y: number } {
      if (!el) return { x: 0, y: 0 };
      const transform = getComputedStyle(el).transform;
      if (!transform || transform === "none") return { x: 0, y: 0 };
      try {
        const m = new DOMMatrix(transform);
        return { x: m.e, y: m.f };
      } catch {
        return { x: 0, y: 0 };
      }
    }

    function updateFadeRegion(wRect: DOMRect) {
      // Find the section the line should be dimmed through (the credo).
      // We re-query each frame because the section may not exist yet on
      // first measure (e.g. during layout settle on slow devices).
      if (!wrapper) return;
      const fadeEl = document.querySelector<HTMLElement>("[data-scroll-line-fade-end]");
      if (!fadeEl || wRect.height <= 0) {
        wrapper.style.setProperty("--scroll-line-fade-end", "0%");
        wrapper.style.setProperty("--scroll-line-fade-alpha", "1");
        return;
      }
      const fadeRect = fadeEl.getBoundingClientRect();
      const fadeEndY = fadeRect.bottom - wRect.top;
      const pct = Math.max(0, Math.min(100, (fadeEndY / wRect.height) * 100));
      wrapper.style.setProperty("--scroll-line-fade-end", `${pct}%`);
      // 0.4 was chosen by eye — dim enough to read as natural over the
      // cream credo bg, bright enough to still trace the line.
      wrapper.style.setProperty("--scroll-line-fade-alpha", "0.18");
    }

    function update() {
      if (!target || !wrapper) return;

      const wRect = wrapper.getBoundingClientRect();
      const tRect = target.getBoundingClientRect();
      const sRect = source ? source.getBoundingClientRect() : null;
      updateFadeRegion(wRect);

      // Walk up from the dot to the wrapper, summing transform offsets so we
      // can subtract any in-flight reveal animation translation.
      let revealOffsetY = 0;
      let revealOffsetX = 0;
      let cur: Element | null = source;
      while (cur && cur !== wrapper.parentElement && cur !== document.body) {
        const t = getTransformY(cur);
        revealOffsetX += t.x;
        revealOffsetY += t.y;
        cur = cur.parentElement;
      }

      const startTopWrap = sRect
        ? sRect.top - wRect.top + sRect.height / 2 - revealOffsetY
        : 0;
      const startX = sRect
        ? sRect.left - wRect.left + sRect.width / 2 - revealOffsetX
        : wRect.width * 0.5;
      // Land the tip right on the button's top edge — small negative so the
      // tip overlaps the button by 1px and visually touches without a gap.
      const endTopWrap = tRect.top - wRect.top + 1;
      const endX = tRect.left + tRect.width / 2 - wRect.left;
      const h = Math.max(0, endTopWrap - startTopWrap);
      const svgW = wRect.width;

      const lightSvg = document.querySelector<SVGSVGElement>("[data-scroll-line-svg-light]");
      const lightPath = document.querySelector<SVGPathElement>("[data-scroll-line-path-light]");

      // Always re-anchor SVG to the dot's current position
      [svg, lightSvg].forEach((s) => {
        if (!s) return;
        s.setAttribute("width", String(svgW));
        s.style.top = `${startTopWrap}px`;
        s.style.height = `${h}px`;
      });

      // Rebuild path only when shape changes — getTotalLength is the slow part
      const dimsChanged =
        Math.abs(h - lastH) > 0.5 ||
        Math.abs(startX - lastStartX) > 0.5 ||
        Math.abs(endX - lastEndX) > 0.5;
      if (dimsChanged) {
        const amp = svgW * 0.4;
        const d = buildPath(startX, endX, h, amp);
        path!.setAttribute("d", d);
        lightPath?.setAttribute("d", d);
        totalLength = path!.getTotalLength();
        [path, lightPath].forEach((p) => {
          if (!p) return;
          p.style.strokeDasharray = String(totalLength);
        });
        lastH = h;
        lastStartX = startX;
        lastEndX = endX;
      }

      if (totalLength === 0) return;

      // Drawing window: starts when the dot enters at 80% of the viewport,
      // ends when the booking button reaches 35% from the top.
      const startThreshold = window.innerHeight * 0.8;
      const endThreshold = window.innerHeight * 0.35;
      const startViewportY = sRect ? sRect.top + sRect.height / 2 : wRect.top;
      const lineHeight = Math.max(1, h);
      const drawDistance = lineHeight + (startThreshold - endThreshold);
      const raw = (startThreshold - startViewportY) / drawDistance;
      const linear = Math.max(0, Math.min(1, raw));
      // 1:1 with scroll for the early/middle portion (start feel unchanged).
      // After ACCEL_FROM the line speeds up at a constant 1.75x rate so it
      // visually completes at COMPLETE_AT — well before the user reaches the
      // end of the scroll window, so they don't have to scroll the full way
      // to "land" the line on the button. No ease-out at the end → no
      // deceleration into the button.
      const ACCEL_FROM = 0.72;
      const COMPLETE_AT = 0.93;
      let progress: number;
      if (linear < ACCEL_FROM) {
        progress = linear;
      } else if (linear >= COMPLETE_AT) {
        progress = 1;
      } else {
        const t = (linear - ACCEL_FROM) / (COMPLETE_AT - ACCEL_FROM);
        progress = ACCEL_FROM + (1 - ACCEL_FROM) * t;
      }
      const offset = totalLength * (1 - progress);

      path!.style.strokeDashoffset = String(offset);
      if (lightPath) lightPath.style.strokeDashoffset = String(offset);

      // Fire the CTA glow the moment the line actually reaches the button
      // (i.e. the same scroll position where progress hits 1.0).
      const arrived = linear >= COMPLETE_AT;
      if (arrived && !ctaReached) {
        ctaReached = true;
        document.dispatchEvent(new CustomEvent("cta-line-reached"));
      } else if (!arrived && ctaReached) {
        ctaReached = false;
        document.dispatchEvent(new CustomEvent("cta-line-left"));
      }
    }

    function bind() {
      setup();
      update();
      // Clear inline opacity/transition that cleanup set, so the CSS class
      // can drive the fade-in. NOTE: we do NOT add is-ready yet — wait
      // until two consecutive update() calls return matching dimensions
      // (i.e. layout has settled). On mobile Safari especially, layout
      // can take 200-500ms after astro:page-load to stabilise; revealing
      // the line before then shows it at the wrong position briefly.
      if (wrapper) {
        wrapper.style.opacity = "";
        wrapper.style.transition = "";
      }

      let stableHits = 0;
      let prevStableH = -1;
      const READY_TIMEOUT_MS = 1500; // hard ceiling — show the line eventually
      const startedAt = performance.now();
      const tryReady = () => {
        if (!wrapper || wrapper.classList.contains("is-ready")) return;
        const prevH = lastH;
        update();
        const stable =
          totalLength > 50 &&
          Math.abs(lastH - prevH) < 0.5 &&
          Math.abs(lastH - prevStableH) < 0.5;
        if (stable) stableHits++;
        else stableHits = 0;
        prevStableH = lastH;
        // Show after 2 stable hits (~300ms of consistent layout) OR after
        // hitting the ceiling — whichever comes first.
        if (stableHits >= 2 || performance.now() - startedAt > READY_TIMEOUT_MS) {
          wrapper.classList.add("is-ready");
          return;
        }
        setTimeout(tryReady, 150);
      };
      setTimeout(tryReady, 80);

      // update() now reanchors the SVG to the dot's current position every
      // frame — but it only runs on scroll events. We need it to also run
      // when layout settles after font loads / reveal animations.
      const resettle = () => update();

      if ((document as any).fonts?.ready) {
        (document as any).fonts.ready.then(resettle);
      }

      const credo = document.querySelector<HTMLElement>(".credo-block");
      const onTransitionEnd = (e: TransitionEvent) => {
        if (e.propertyName === "transform" || e.propertyName === "opacity") {
          resettle();
        }
      };
      credo?.addEventListener("transitionend", onTransitionEnd);

      // Belt-and-suspenders timeouts — catch any layout shift that the
      // events above missed (slow fonts, animation-after-IO timing, etc.).
      const timeouts = [200, 600, 1200, 2400, 4000].map((ms) =>
        window.setTimeout(resettle, ms)
      );

      // Reflow watcher: anything that changes the credo's box → resettle.
      let credoObserver: ResizeObserver | null = null;
      if (credo && "ResizeObserver" in window) {
        credoObserver = new ResizeObserver(resettle);
        credoObserver.observe(credo);
      }
      // Same for the page body — catches late-loading content above the line.
      let bodyObserver: ResizeObserver | null = null;
      if ("ResizeObserver" in window) {
        bodyObserver = new ResizeObserver(resettle);
        bodyObserver.observe(document.body);
      }

      // Single RAF gate so multiple scroll events in one frame collapse to
      // one update() call. Prevents stuttering / frame-by-frame draws.
      let rafScheduled = false;
      const onScroll = () => {
        if (rafScheduled) return;
        rafScheduled = true;
        requestAnimationFrame(() => {
          rafScheduled = false;
          update();
        });
      };
      const onResize = () => {
        setup();
        update();
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onResize);

      __slCleanup = () => {
        window.removeEventListener("scroll", onScroll);
        window.removeEventListener("resize", onResize);
        credo?.removeEventListener("transitionend", onTransitionEnd);
        credoObserver?.disconnect();
        bodyObserver?.disconnect();
        timeouts.forEach((id) => window.clearTimeout(id));
        // Force IMMEDIATE invisibility — the CSS opacity transition (0.6s)
        // would otherwise leave a fading ghost during the 300ms view-
        // transition cross-fade. Inline style beats the class.
        if (wrapper) {
          wrapper.style.opacity = "0";
          wrapper.style.transition = "none";
          wrapper.classList.remove("is-ready");
        }
        // Clear path geometry so the snapshot has no stale data to display
        // alongside the freshly-mounted SVG.
        const lp = document.querySelector<SVGPathElement>("[data-scroll-line-path-light]");
        path?.removeAttribute("d");
        lp?.removeAttribute("d");
        // Wipe inline strokeDashoffset/strokeDasharray too — snapshot may
        // capture computed style, not just attributes.
        if (path) {
          path.style.strokeDashoffset = "";
          path.style.strokeDasharray = "";
        }
        if (lp) {
          lp.style.strokeDashoffset = "";
          lp.style.strokeDasharray = "";
        }
        // Reset cached dims so the next bind() rebuilds the path fresh.
        lastH = 0;
        lastStartX = 0;
        lastEndX = 0;
        totalLength = 0;
      };
    }

    // Wait for layout (especially fonts + images that affect heights) before measuring
    if (document.readyState === "complete") {
      requestAnimationFrame(bind);
    } else {
      window.addEventListener("load", () => requestAnimationFrame(bind), { once: true });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initScrollLine);
  } else {
    initScrollLine();
  }
  document.addEventListener("astro:page-load", initScrollLine);

  // Run cleanup BEFORE the browser snapshots the page for view transitions.
  // - astro:before-preparation fires before the snapshot is captured. This
  //   is the critical one — clearing the path d here means the snapshot has
  //   no line geometry to ghost during the cross-fade.
  // - astro:before-swap fires after snapshot, before DOM replace; kept as a
  //   secondary safety so the new page DOM starts clean.
  // - pagehide fires for full navigations (no view transitions); covers the
  //   case where the user disables view transitions or browser doesn't run them.
  const cleanupOnNavigate = () => __slCleanup?.();
  document.addEventListener("astro:before-preparation", cleanupOnNavigate);
  document.addEventListener("astro:before-swap", cleanupOnNavigate);
  window.addEventListener("pagehide", cleanupOnNavigate);
</script>
